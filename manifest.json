{

    "name": "Dragon",
    "version": "0.5.0.9",
    "manifest_version": 3,
    "description": "Decentralizing token data to discover alpha.",
    "background": {
        "service_worker": "service-worker.js"
    },
    "icons": {
        "128": "images/icon-128.png",
        "16": "images/icon-16.png"
    },
    "side_panel": {
        "default_path": "sidepanel.html"
    },
    "permissions": [
        "sidePanel"
    ],
    "host_permissions": [
        "https://dragon-backend-829421338007.us-central1.run.app/*"
        
    ],
    "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src 'self' https://dragon-backend-829421338007.us-central1.run.app; img-src 'self' https://imagedelivery.net"
    }

}
